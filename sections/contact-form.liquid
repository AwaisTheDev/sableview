{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-tabs {
    display: flex;
    gap: 0;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.08);
    margin-bottom: 3rem;
  }

  .contact-tabs__button {
    background: none;
    border: none;
    padding: 1.5rem 3rem;
    font-size: 1.8rem;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: 0.06rem;
    cursor: pointer;
    color: rgba(var(--color-foreground), 0.45);
    border-bottom: 0.3rem solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact-tabs__button[aria-selected="true"] {
    color: rgb(var(--color-foreground));
    border-bottom-color: rgb(var(--color-foreground));
  }

  .contact-tabs__button:hover {
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    .contact-tabs__button {
      font-size: 2.2rem;
      padding: 1.5rem 3.5rem;
    }
  }

  .contact-tabs__panel {
    display: none;
  }

  .contact-tabs__panel[data-active] {
    display: block;
  }

  .feedback-form__question {
    margin-bottom: 2.5rem;
    border: none;
    padding: 0;
  }

  .feedback-form__question legend {
    font-weight: var(--font-body-weight-bold);
    margin-bottom: 1rem;
    font-size: 1.5rem;
    padding: 0;
  }

  .feedback-form__option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
  }

  .feedback-form__option input[type="checkbox"],
  .feedback-form__option input[type="radio"] {
    width: 1.8rem;
    height: 1.8rem;
    accent-color: rgb(var(--color-button));
    flex-shrink: 0;
  }

  .feedback-form__option label {
    cursor: pointer;
    font-size: 1.4rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- else -%}
      <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
    {%- endif -%}

    <!-- Tabs -->
    <div class="contact-tabs" role="tablist">
      <button
        class="contact-tabs__button"
        role="tab"
        id="tab-contact-{{ section.id }}"
        aria-selected="true"
        aria-controls="panel-contact-{{ section.id }}"
        type="button"
      >
        {{ section.settings.tab_contact_label | default: 'Contact Us' }}
      </button>
      <button
        class="contact-tabs__button"
        role="tab"
        id="tab-feedback-{{ section.id }}"
        aria-selected="false"
        aria-controls="panel-feedback-{{ section.id }}"
        type="button"
      >
        {{ section.settings.tab_feedback_label | default: 'Feedback' }}
      </button>
    </div>

    <!-- Tab Panel: Contact Us -->
    <div
      class="contact-tabs__panel"
      role="tabpanel"
      id="panel-contact-{{ section.id }}"
      aria-labelledby="tab-contact-{{ section.id }}"
      data-active
    >
      {%- if section.settings.contact_description != blank -%}
        <div class="rte" style="margin-bottom: 2rem;">{{ section.settings.contact_description }}</div>
      {%- endif -%}
      {%- liquid
        assign contact_form_class = 'isolate'
        if settings.animations_reveal_on_scroll
          assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
        endif
      -%}
      {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
        {%- if form.posted_successfully? -%}
          <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
            {{- 'icon-success.svg' | inline_asset_content -}}
            {{ 'templates.contact.form.post_success' | t }}
          </h2>
        {%- elsif form.errors -%}
          <div class="form__message">
            <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              {{- 'icon-error.svg' | inline_asset_content -}}
              {{ 'templates.contact.form.error_heading' | t }}
            </h2>
          </div>
          <ul class="form-status-list caption-large" role="list">
            <li>
              <a href="#ContactForm-email" class="link">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </a>
            </li>
          </ul>
        {%- endif -%}
        <div class="contact__fields">
          <div class="field">
            <input
              class="field__input"
              autocomplete="name"
              type="text"
              id="ContactForm-name"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'templates.contact.form.name' | t }}"
            >
            <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
          </div>
          <div class="field field--with-error">
            <input
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              class="field__input"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{ 'templates.contact.form.email' | t }}"
            >
            <label class="field__label" for="ContactForm-email">
              {{- 'templates.contact.form.email' | t }}
              <span aria-hidden="true">*</span></label
            >
            {%- if form.errors contains 'email' -%}
              <small class="contact__field-error" id="ContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message">
                  <span class="svg-wrapper">
                    {{- 'icon-error.svg' | inline_asset_content -}}
                  </span>
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
        </div>
        <div class="field">
          <input
            type="tel"
            id="ContactForm-phone"
            class="field__input"
            autocomplete="tel"
            name="contact[{{ 'templates.contact.form.phone' | t }}]"
            pattern="[0-9\-]*"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            placeholder="{{ 'templates.contact.form.phone' | t }}"
          >
          <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
        </div>
        <div class="field">
          <textarea
            rows="10"
            id="ContactForm-body"
            class="text-area field__input"
            name="contact[{{ 'templates.contact.form.comment' | t }}]"
            placeholder="{{ 'templates.contact.form.comment' | t }}"
          >
            {{- form.body -}}
          </textarea>
          <label class="form__label field__label" for="ContactForm-body">
            {{- 'templates.contact.form.comment' | t -}}
          </label>
        </div>
        <div class="contact__button">
          <button type="submit" class="button">
            {{ 'templates.contact.form.send' | t }}
          </button>
        </div>
      {%- endform -%}
    </div>

    <!-- Tab Panel: Feedback -->
    <div
      class="contact-tabs__panel"
      role="tabpanel"
      id="panel-feedback-{{ section.id }}"
      aria-labelledby="tab-feedback-{{ section.id }}"
    >
      {%- if section.settings.feedback_description != blank -%}
        <p class="rte" style="margin-bottom: 2rem;">{{ section.settings.feedback_description }}</p>
      {%- endif -%}

      {%- form 'contact', id: 'FeedbackForm', class: 'isolate' -%}
        <input type="hidden" name="contact[tags]" value="feedback,beef-box-questionnaire">
        <input type="hidden" name="contact[subject]" value="Beef Box Feedback Questionnaire">

        {%- if form.posted_successfully? -%}
          <h3 class="form-status form-status-list form__message" tabindex="-1" autofocus>
            <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
            {{ section.settings.feedback_success_message | default: 'Thank you for your feedback!' }}
          </h3>
        {%- elsif form.errors -%}
          <div class="form__message">
            <h3 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              Something went wrong. Please try again.
            </h3>
          </div>
        {%- endif -%}

        {%- unless form.posted_successfully? -%}
          <div class="contact__fields">
            <div class="field">
              <input
                class="field__input"
                type="email"
                id="FeedbackForm-email-{{ section.id }}"
                name="contact[email]"
                autocomplete="email"
                aria-required="true"
                placeholder="Your email"
                required
              >
              <label class="field__label" for="FeedbackForm-email-{{ section.id }}">Your email *</label>
            </div>
          </div>

          <fieldset class="feedback-form__question">
            <legend>1. Which Beef Box did you receive?</legend>
            <div class="feedback-form__option">
              <input type="radio" id="box-5kg-{{ section.id }}" name="contact[Beef Box Received]" value="5kg Box – Starter Box">
              <label for="box-5kg-{{ section.id }}">5kg Box – Starter Box</label>
            </div>
            <div class="feedback-form__option">
              <input type="radio" id="box-10kg-{{ section.id }}" name="contact[Beef Box Received]" value="10kg Box – Farmhouse Box">
              <label for="box-10kg-{{ section.id }}">10kg Box – Farmhouse Box</label>
            </div>
            <div class="feedback-form__option">
              <input type="radio" id="box-20kg-{{ section.id }}" name="contact[Beef Box Received]" value="20kg Box – Sableview Signature Box">
              <label for="box-20kg-{{ section.id }}">20kg Box – Sableview Signature Box</label>
            </div>
            <div class="feedback-form__option">
              <input type="radio" id="box-other-{{ section.id }}" name="contact[Beef Box Received]" value="Other">
              <label for="box-other-{{ section.id }}">Other</label>
            </div>
            <div class="field" style="margin-top: 1rem;">
              <input
                class="field__input"
                type="text"
                id="box-other-specify-{{ section.id }}"
                name="contact[Beef Box Other]"
                placeholder="If other, please specify"
              >
              <label class="field__label" for="box-other-specify-{{ section.id }}">If other, please specify</label>
            </div>
          </fieldset>

          <fieldset class="feedback-form__question">
            <legend>2. Which cuts were your favourites? (Select all that apply)</legend>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-rib-{{ section.id }}" name="contact[Favourite Cuts][]" value="Rib Fillet">
              <label for="cut-rib-{{ section.id }}">Rib Fillet</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-rump-{{ section.id }}" name="contact[Favourite Cuts][]" value="Rump Steak">
              <label for="cut-rump-{{ section.id }}">Rump Steak</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-tbone-{{ section.id }}" name="contact[Favourite Cuts][]" value="T-Bone Steak">
              <label for="cut-tbone-{{ section.id }}">T-Bone Steak</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-eye-{{ section.id }}" name="contact[Favourite Cuts][]" value="Eye Fillet">
              <label for="cut-eye-{{ section.id }}">Eye Fillet</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-burgers-{{ section.id }}" name="contact[Favourite Cuts][]" value="Brisket Burgers">
              <label for="cut-burgers-{{ section.id }}">Brisket Burgers</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-sausage-mince-{{ section.id }}" name="contact[Favourite Cuts][]" value="Sausage Mince">
              <label for="cut-sausage-mince-{{ section.id }}">Sausage Mince</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-premium-mince-{{ section.id }}" name="contact[Favourite Cuts][]" value="Premium Mince">
              <label for="cut-premium-mince-{{ section.id }}">Premium Mince</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-sausages-{{ section.id }}" name="contact[Favourite Cuts][]" value="Beef Sausages">
              <label for="cut-sausages-{{ section.id }}">Beef Sausages</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-slow-{{ section.id }}" name="contact[Favourite Cuts][]" value="Slow-Cook Cuts (e.g. diced beef, chuck)">
              <label for="cut-slow-{{ section.id }}">Slow-Cook Cuts (e.g. diced beef, chuck)</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="cut-roast-{{ section.id }}" name="contact[Favourite Cuts][]" value="Roast Cuts (e.g. oyster blade roast)">
              <label for="cut-roast-{{ section.id }}">Roast Cuts (e.g. oyster blade roast)</label>
            </div>
          </fieldset>

          <fieldset class="feedback-form__question">
            <legend>3. Which sausage variety was your favourite? (Select one or more)</legend>
            <div class="feedback-form__option">
              <input type="checkbox" id="sausage-keto-{{ section.id }}" name="contact[Favourite Sausage][]" value="Keto Sausage">
              <label for="sausage-keto-{{ section.id }}">Keto Sausage</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="sausage-plain-{{ section.id }}" name="contact[Favourite Sausage][]" value="Plain Sausage">
              <label for="sausage-plain-{{ section.id }}">Plain Sausage</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="sausage-chilli-{{ section.id }}" name="contact[Favourite Sausage][]" value="Chilli & Honey Sausage">
              <label for="sausage-chilli-{{ section.id }}">Chilli & Honey Sausage</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="sausage-turmeric-{{ section.id }}" name="contact[Favourite Sausage][]" value="Turmeric Sausage">
              <label for="sausage-turmeric-{{ section.id }}">Turmeric Sausage</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="sausage-mince-{{ section.id }}" name="contact[Favourite Sausage][]" value="Sausage Mince">
              <label for="sausage-mince-{{ section.id }}">Sausage Mince</label>
            </div>
          </fieldset>

          <fieldset class="feedback-form__question">
            <legend>4. Is there anything you would like to see changed or included in future Beef Boxes? (Select all that apply)</legend>
            <div class="feedback-form__option">
              <input type="checkbox" id="change-cuts-{{ section.id }}" name="contact[Future Changes][]" value="Different cuts">
              <label for="change-cuts-{{ section.id }}">Different cuts</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="change-customise-{{ section.id }}" name="contact[Future Changes][]" value="Greater ability to customise or choose specific cuts">
              <label for="change-customise-{{ section.id }}">Greater ability to customise or choose specific cuts</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="change-bones-{{ section.id }}" name="contact[Future Changes][]" value="Bones or pet mince included">
              <label for="change-bones-{{ section.id }}">Bones or pet mince included</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="change-smaller-{{ section.id }}" name="contact[Future Changes][]" value="Smaller pack sizes">
              <label for="change-smaller-{{ section.id }}">Smaller pack sizes</label>
            </div>
            <div class="feedback-form__option">
              <input type="checkbox" id="change-other-{{ section.id }}" name="contact[Future Changes][]" value="Other suggestions">
              <label for="change-other-{{ section.id }}">Other suggestions</label>
            </div>
          </fieldset>

          <div class="field">
            <textarea
              rows="4"
              id="FeedbackForm-comments-{{ section.id }}"
              class="text-area field__input"
              name="contact[body]"
              placeholder="Additional comments or suggestions"
            ></textarea>
            <label class="form__label field__label" for="FeedbackForm-comments-{{ section.id }}">Additional comments</label>
          </div>

          <div class="contact__button" style="margin-top: 2rem;">
            <button type="submit" class="button">Submit Feedback</button>
          </div>
        {%- endunless -%}
      {%- endform -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var tabs = document.querySelectorAll('#tab-contact-' + sectionId + ', #tab-feedback-' + sectionId);
    var panels = document.querySelectorAll('#panel-contact-' + sectionId + ', #panel-feedback-' + sectionId);

    function activateTab(tab) {
      tabs.forEach(function(t) { t.setAttribute('aria-selected', 'false'); });
      panels.forEach(function(p) { p.removeAttribute('data-active'); });
      tab.setAttribute('aria-selected', 'true');
      var panelId = tab.getAttribute('aria-controls');
      document.getElementById(panelId).setAttribute('data-active', '');
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        activateTab(tab);
        var hash = tab.id.indexOf('feedback') > -1 ? '#feedback' : '#contact';
        history.replaceState(null, '', hash);
      });
    });

    if (window.location.hash === '#feedback') {
      activateTab(document.getElementById('tab-feedback-' + sectionId));
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.contact-form.settings.title.default",
      "label": "t:sections.contact-form.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "text",
      "id": "tab_contact_label",
      "default": "Contact Us",
      "label": "Contact tab label"
    },
    {
      "type": "text",
      "id": "tab_feedback_label",
      "default": "Feedback",
      "label": "Feedback tab label"
    },
    {
      "type": "header",
      "content": "Contact form"
    },
    {
      "type": "richtext",
      "id": "contact_description",
      "label": "Contact form description",
      "default": "<p>Have a question or need help? Fill out the form below and we'll get back to you as soon as possible.</p>"
    },
    {
      "type": "header",
      "content": "Feedback form"
    },
    {
      "type": "richtext",
      "id": "feedback_description",
      "default": "<p>Thank you for choosing a Sableview Farm Beef Box. We value your feedback and would appreciate you taking a few minutes to share your experience.</p>",
      "label": "Feedback description"
    },
    {
      "type": "text",
      "id": "feedback_success_message",
      "default": "Thank you for your feedback! We greatly appreciate your support of Sableview Farm.",
      "label": "Feedback success message"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
